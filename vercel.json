{
  "cleanUrls": true,
  "trailingSlash": false,
  "routes": [
    {
      "src": "^/stage-(?:[1-9]|10)$",
      "dest": "/"
    },
    {
      "src": "^/complete$",
      "dest": "/"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0"
        }
      ]
    }
  ]
}
